# ── Minuteman Marketing Agent ──

# Mode: "demo" uses mock data, "live" connects to real APIs
APP_MODE=demo
PORT=3000

# ── Service Titan ──
SERVICE_TITAN_CLIENT_ID=
SERVICE_TITAN_CLIENT_SECRET=
SERVICE_TITAN_TENANT_ID=
SERVICE_TITAN_APP_KEY=

# ── Hatch (SMS) ──
HATCH_API_KEY=
HATCH_COMPANY_ID=

# ── Email (SMTP) ──
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM_NAME=Minuteman Plumbing
EMAIL_FROM_ADDRESS=info@minutemanplumbing.com

# ── Google Review ──
GOOGLE_REVIEW_LINK=https://g.page/r/minuteman-plumbing/review

# ── OpenRouter (AI Classification) ──
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-preview

# ── Guardrails ──
DAILY_SMS_CAP=50
DAILY_EMAIL_CAP=100
REVIEW_REQUEST_DELAY_HOURS=2
ESTIMATE_FOLLOWUP_DELAY_HOURS=48

# ── Admin ──
ADMIN_USERNAME=nat
ADMIN_PASSWORD=minuteman2026
